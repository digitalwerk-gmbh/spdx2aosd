{
  "name": "spdx2aosd",
  "version": "1.5.0-beta",
  "author": "Digitalwerk GmbH",
  "description": "cli tool for converting different formats into the aosd json format. GroupSpec (AUDI, VW) spdx2.3 to aosd2.1 JSON converter written in typescript.",
  "license": "MPL-2.0",
  "copyright": "Copyright 2024 (c) Digitalwerk GmbH",
  "main": "main.ts",
  "scripts": {
    "upxls": "cross-env RUN_MODE=production SCRIPT=upxls ts-node main.ts",
    "upcsv": "cross-env RUN_MODE=production SCRIPT=upcsv ts-node main.ts",
    "up": "cross-env RUN_MODE=production SCRIPT=up ts-node main.ts",
    "down": "cross-env RUN_MODE=production SCRIPT=down ts-node main.ts",
    "spdx": "cross-env RUN_MODE=production SCRIPT=spdx ts-node main.ts",
    "accumulate": "cross-env RUN_MODE=production SCRIPT=accumulate ts-node main.ts",
    "licenses": "cross-env RUN_MODE=production ts-node ./src/licenses.ts",
    "test": "cross-env RUN_MODE=test INPUT_JSON_PATH=./tests/data/input/ OUTPUT_JSON_PATH=./tests/data/output/ jest --detectOpenHandles"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "gitlab",
    "url": "gitlab+https://gitlab.com/digitalwerk/checkoss/aosdtoaosdconverter.git"
  },
  "keywords": [
    "aosd2.1",
    "aosd2.0",
    "spdx2.3",
    "converter",
    "json",
    "groupspec",
    "scheme",
    "licenses"
  ],
  "dependencies": {
    "@fast-csv/parse": "^5.0.5",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "axios": "^1.11.0",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "fast-csv": "^5.0.5",
    "JSONStream": "^1.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@jest/globals": "^30.1.2",
    "@types/node": "^24.3.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
